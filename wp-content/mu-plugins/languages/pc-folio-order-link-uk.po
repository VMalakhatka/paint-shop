#: pc-folio-order-link.php:141
msgid "Order not found."
msgstr "Замовлення не знайдено."

#: pc-folio-order-link.php:150
msgid "Document ID"
msgstr "ID документа"

#: pc-folio-order-link.php:151
msgid "Document number"
msgstr "Номер документа"

#: pc-folio-order-link.php:152
msgid "Document type"
msgstr "Тип документа"

#: pc-folio-order-link.php:153
