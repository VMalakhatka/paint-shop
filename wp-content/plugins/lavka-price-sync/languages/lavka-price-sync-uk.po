#. Plugin Name of the plugin
#: lavka-price-sync.php inc/admin-ui.php:7 inc/admin-ui.php:102
msgid "Lavka Price Sync"
msgstr "Синхронізація цін Lavka"

#. Description of the plugin
#: lavka-price-sync.php
msgid ""
"Sync role-based prices from Java service to WooCommerce (meta: "
"_wpc_price_role_<role>)."
msgstr ""
"Синхронізація цін за ролями з Java-сервісу до WooCommerce (мета: "
"_wpc_price_role_<роль>)."

