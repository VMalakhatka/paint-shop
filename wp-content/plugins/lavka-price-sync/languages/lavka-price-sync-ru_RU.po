#: inc/admin-ui.php:288
#, php-format
msgid ""
"Launch completed: ok=%1$s, updated_retail=%2$d, updated_roles=%3$d, "
"not_found=%4$d"
msgstr ""
"Запуск завершён: ok=%1$s, обновлено розничных=%2$d, ролевых=%3$d, не найдено="
"%4$d"

#: inc/admin-ui.php:296
msgid "Schedule saved"
msgstr "Расписание сохранено"

#: inc/admin-ui.php:312
msgid ""
"Uses mapping from the Mapping page. For each SKU the endpoint returns retail "
"price and all role prices. The plugin updates _regular_price/_price and "
"_wpc_price_role_<role>."
msgstr ""
"Использует соответствия с вкладки Mapping. Для каждого SKU эндпоинт "
"возвращает розничную и ролевые цены. Плагин обновляет _regular_price/_price "
"и _wpc_price_role_<роль>."

