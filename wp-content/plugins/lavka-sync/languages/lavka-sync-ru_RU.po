#. Plugin Name of the plugin
#: lavka-sync.php inc/admin-ui.php:642
msgid "Lavka Sync"
msgstr "Lavka Sync"

#. Description of the plugin
#: lavka-sync.php
msgid ""
"Provides buttons and settings to synchronize with the Java service and "
"exposes a REST API."
msgstr ""
"Предоставляет кнопки и настройки для синхронизации с Java-сервисом и "
"открывает REST API."

