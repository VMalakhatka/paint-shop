#. Plugin Name of the plugin
#: lavka-sync.php inc/admin-ui.php:650
msgid "Lavka Sync"
msgstr "Lavka Sync"

#. Description of the plugin
#: lavka-sync.php
msgid ""
"Provides buttons and settings to synchronize with the Java service and "
"exposes a REST API."
msgstr ""
"Надає кнопки та налаштування для синхронізації з Java-сервісом і відкриває "
"REST API."

